<section class="section">
  <div class="container">
    <div class="hero-layout">
      <aside class="hero-categories">
        <h2>{{ section.settings.sidebar_heading }}</h2>
        <ul>
          {%- for block in section.blocks -%}
            {%- if block.type == 'category' -%}
              <li {{ block.shopify_attributes }}><a href="{{ block.settings.link }}">{{ block.settings.label }}</a></li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </aside>

      <div class="hero-slider" data-hero-slider>
        {%- assign has_active_slide = false -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'slide' -%}
            <div class="hero-slide {% unless has_active_slide %}active{% endunless %}" style="background-image: url('{{ block.settings.image | image_url: width: 1800 }}');" {{ block.shopify_attributes }}>
              <div class="hero-overlay">
                <div class="hero-content">
                  <h1>{{ block.settings.heading }}</h1>
                  <p>{{ block.settings.subheading }}</p>
                  <a class="btn btn-primary" href="{{ block.settings.cta_link }}">{{ block.settings.cta_text }}</a>
                </div>
              </div>
            </div>
            {%- assign has_active_slide = true -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "max_blocks": 16,
  "settings": [
    { "type": "text", "id": "sidebar_heading", "label": "Sidebar heading", "default": "Browse Categories" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Sidebar category",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Beauty" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    },
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Global B2B Product Showcase" },
        { "type": "text", "id": "subheading", "label": "Subheading", "default": "Source verified products for cross-border growth." },
        { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Explore Products" },
        { "type": "url", "id": "cta_link", "label": "CTA link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        { "type": "category", "settings": { "label": "Beauty" } },
        { "type": "category", "settings": { "label": "Health" } },
        { "type": "category", "settings": { "label": "Oral Care" } },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
