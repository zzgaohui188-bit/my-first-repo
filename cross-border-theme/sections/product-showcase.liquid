<section class="section">
  <div class="container">
    <div class="section-head-inline">
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.collection != blank -%}
        <a class="btn btn-outline" href="{{ section.settings.collection.url }}">View all</a>
      {%- endif -%}
    </div>
    <div class="grid product-grid">
      {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
        {% render 'product-card', product: product %}
      {%- else -%}
        <p>No products found in this collection.</p>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Showcase",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Skincare Products" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products", "min": 4, "max": 12, "step": 1, "default": 4 }
  ],
  "presets": [{ "name": "Product Showcase" }]
}
{% endschema %}
