<section class="section">
  <div class="container">
    <h2 class="section-heading">{{ section.settings.heading }}</h2>
    <div class="grid categories-grid">
      {%- for block in section.blocks -%}
        {%- assign collection = block.settings.collection -%}
        <a class="card category-card" href="{{ collection.url }}">
          {%- if collection.featured_image -%}
            {{ collection.featured_image | image_url: width: 600 | image_tag: alt: collection.title }}
          {%- endif -%}
          <div class="card-content">
            <h3>{{ collection.title }}</h3>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category Grid",
  "max_blocks": 6,
  "settings": [{ "type": "text", "id": "heading", "label": "Heading", "default": "Product Categories" }],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [{ "type": "collection", "id": "collection", "label": "Collection" }]
    }
  ],
  "presets": [{ "name": "Category Grid" }]
}
{% endschema %}
