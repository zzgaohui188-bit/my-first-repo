<section class="section category-strip-section">
  <div class="container">
    <div class="category-strip" role="list">
      {%- for block in section.blocks -%}
        <a class="category-pill" href="{{ block.settings.link }}" role="listitem" {{ block.shopify_attributes }}>
          <span class="category-icon">{{ block.settings.icon }}</span>
          <span>{{ block.settings.label }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category Icon Strip",
  "max_blocks": 12,
  "blocks": [
    {
      "type": "item",
      "name": "Category",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon text", "default": "🧴" },
        { "type": "text", "id": "label", "label": "Label", "default": "Skincare" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [{ "name": "Category Icon Strip" }]
}
{% endschema %}
